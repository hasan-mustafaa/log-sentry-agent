# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set the API key for your chosen LLM provider.
# Only one is needed at runtime; the active provider is set in config/config.yaml.

OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional overrides ─────────────────────────────────────────────────────────
# These override values in config/config.yaml when set.

# LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
# DASHBOARD_PORT=8501      # Streamlit default port
